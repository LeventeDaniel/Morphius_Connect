# Morphius Connect — Environment Secret References
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is .gitignored.
# These values are referenced by token_ref / key_ref fields in connect.yaml.

# Example: local LLM API key (if your local server requires one)
LOCAL_LLM_API_KEY=your-local-llm-key-here

# Example: cloud LLM provider key
CLOUD_LLM_API_KEY=your-cloud-llm-key-here

# Example: coding API bearer token
CODING_API_TOKEN=your-coding-api-token-here

# Example: database connection string
DATABASE_URL=your-database-url-here

# Example: webhook signing secret
WEBHOOK_SECRET=your-webhook-secret-here

# Example: generic cloud API key
GENERIC_API_KEY=your-generic-api-key-here

# Add more as needed — one variable per connection secret.
# Reference these from connect.yaml using:  token_ref: VARIABLE_NAME
